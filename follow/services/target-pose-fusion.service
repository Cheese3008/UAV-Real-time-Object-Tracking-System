[Unit]
Description=Target Pose Fusion (Kalman Filter) ROS2 Node
After=microxrce-agent.service

[Service]
Type=simple
User=pihuy
WorkingDirectory=/home/pihuy/follow
ExecStart=/bin/bash /home/pihuy/follow/services/run_kalman_filter.sh
Restart=always
KillSignal=SIGINT
RestartSec=2

Environment=RMW_IMPLEMENTATION=rmw_fastrtps_cpp
Environment=RMW_FASTRTPS_USE_SHM=0
Environment=ROS_DOMAIN_ID=0
Environment=HOME=/home/pihuy


[Install]
WantedBy=multi-user.target
