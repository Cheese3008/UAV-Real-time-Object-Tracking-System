[Unit]
Description=Yolo ROS2
After=microxrce-agent.service 

[Service]
Type=simple
User=pihuy
WorkingDirectory=/home/pihuy/follow
ExecStart=/bin/bash /home/pihuy/follow/services/run_ai_follow.sh
Restart=always
RestartSec=3
KillSignal=SIGINT
Environment=RMW_IMPLEMENTATION=rmw_fastrtps_cpp
Environment=RMW_FASTRTPS_USE_SHM=0
Environment=ROS_DOMAIN_ID=0
Environment=HOME=/home/pihuy


[Install]
WantedBy=multi-user.target
